                <span class="qm-chip" role="button" tabindex="0">
                  <svg viewBox="0 0 512 512" fill="currentColor" class="qm-icon"><path d="M428.5 40.3l-224 49.8c-7.3 1.6-12.5 8.1-12.5 15.6l0 74.4 256-56.9 0-67.3c0-10.2-9.5-17.8-19.5-15.6zM448 276.4l0-120.4-256 56.9 0 187.2c0 44.2-43 80-96 80s-96-35.8-96-80 43-80 96-80c24.6 0 47 7.7 64 20.4l0-234.7c0-22.5 15.6-42 37.6-46.9L421.6 9c30-6.7 58.4 16.1 58.4 46.9L480 336c0 44.2-43 80-96 80s-96-35.8-96-80 43-80 96-80c24.6 0 47 7.7 64 20.4zm0 59.6c0-26.5-28.7-48-64-48s-64 21.5-64 48 28.7 48 64 48 64-21.5 64-48zM160 400c0-26.5-28.7-48-64-48s-64 21.5-64 48 28.7 48 64 48 64-21.5 64-48z"/></svg>
