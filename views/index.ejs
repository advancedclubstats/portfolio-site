<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= config.name %> · <%= config.role %></title>

  <meta name="description" content="<%= config.metaDescription %>" />
  <meta name="author" content="<%= config.name %>" />
  <link rel="canonical" href="<%= config.baseUrl %>/" />

  <!-- Open Graph -->
  <meta property="og:type" content="profile" />
  <meta property="og:title" content="<%= config.name %> · <%= config.role %>" />
  <meta property="og:description" content="<%= config.metaDescription %>" />
  <meta property="og:url" content="<%= config.baseUrl %>/" />
  <meta property="profile:first_name" content="Matt" />
  <meta property="profile:last_name" content="Martin" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content="<%= config.name %> · <%= config.role %>" />
  <meta name="twitter:description" content="<%= config.metaDescription %>" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&family=Bricolage+Grotesque:opsz,wght@12..96,500;700&family=Martian+Mono:wght@500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />

  <!-- Structured data: helps an AI answer "who is Matt Martin" accurately -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Matt Martin",
    "alternateName": "Matthew Martin",
    "url": "<%= config.baseUrl %>/",
    "email": "mailto:<%= config.email %>",
    "jobTitle": "Growth & Monetization Product Manager",
    "description": "<%= config.metaDescription %>",
    "knowsAbout": [
      "Product Management", "Growth", "Monetization", "Pricing strategy",
      "Conversion optimization", "Onboarding", "Experimentation",
      "Marketplace products", "Subscription products"
    ],
    "worksFor": { "@type": "Organization", "name": "Independent / open to opportunities" },
    "alumniOf": { "@type": "Organization", "name": "Outschool" },
    "sameAs": [
      "<%= config.roundRecallUrl %>"<% if (config.linkedin) { %>,
      "<%= config.linkedin %>"<% } %>
    ]
  }
  </script>
</head>
<body>
  <a class="skip" href="#work">Skip to work</a>

  <!-- NAME + SOCIALS (the only things outside a card) -->
  <div class="topbar" id="home">
    <span class="mark"><%= config.name %></span>
    <nav class="socials" aria-label="Contact links">
      <a href="mailto:<%= config.email %>">Email</a><% if (config.linkedin) { %>
      <a href="<%= config.linkedin %>" target="_blank" rel="noopener">LinkedIn</a><% } %>
      <a href="<%= config.roundRecallUrl %>" target="_blank" rel="noopener">RoundRecall</a>
    </nav>
  </div>

  <main>
    <!-- HOME: intro card -->
    <section class="section" aria-label="Intro">
      <div class="bento">
        <div class="card card-text card-xl reveal">
          <div class="card-pad">
            <p class="card-eyebrow"><%= config.intro.eyebrow %></p>
            <h1 class="card-head display"><%= config.intro.head %></h1>
            <% config.intro.body.forEach(function(p){ %>
            <p class="card-para"><%= p %></p>
            <% }); %>
          </div>
        </div>
      </div>
    </section>

    <!-- ABOUT: what I do / what I want, all cards -->
    <section class="section" id="about" aria-label="About">
      <div class="bento">
        <div class="card card-text card-md reveal">
          <div class="card-pad">
            <p class="card-eyebrow">What I do</p>
            <ul class="stack">
              <% config.whatIDo.forEach(function(line){ %>
              <li><%= line %></li>
              <% }); %>
            </ul>
          </div>
        </div>

        <div class="card card-text card-md reveal">
          <div class="card-pad">
            <p class="card-eyebrow">What I want</p>
            <ul class="stack">
              <% config.whatIWant.forEach(function(line){ %>
              <li><%= line %></li>
              <% }); %>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- WORK: screenshot-first cards -->
    <section class="section" id="work" aria-label="Work">
      <div class="bento">
        <% projects.forEach(function(p){ %>
        <a class="card card-<%= p.size %> reveal" href="/work/<%= p.slug %>">
          <% if (p.phoneMock) { %>
          <span class="shot phone-shot" aria-label="RoundRecall dashboard preview, scrollable">
            <span class="phone">
            <span class="phone-frame">
              <span class="phone-island"></span>
              <span class="phone-screen">
                <span class="pm-appbar">Dashboard</span>

                <span class="pm-leak">
                  <span class="pm-leak-top">
                    <span class="pm-eyebrow">Biggest leak</span>
                    <span class="pm-leak-label">Putts 10&ndash;20 ft</span>
                    <span class="pm-leak-number">&minus;0.77<span class="pm-unit">/ round</span></span>
                    <span class="pm-leak-sub">8% made vs scratch &asymp; 22% &middot; across 90 shots</span>
                  </span>
                  <span class="pm-leak-strip"><b>Putting</b> holding steady over your last 3 rounds</span>
                </span>

                <span class="pm-section">Scoring shape</span>
                <span class="pm-stat">
                  <span class="pm-stat-num">+16%</span>
                  <span class="pm-stat-sub">birdies &minus; doubles per hole</span>
                </span>
                <span class="pm-bar">
                  <span class="pm-bar-seg" style="width:1%;background:#1e8f59"></span>
                  <span class="pm-bar-seg" style="width:18%;background:rgba(30,143,89,.7)"></span>
                  <span class="pm-bar-seg" style="width:56%;background:rgba(20,32,26,.25)"></span>
                  <span class="pm-bar-seg" style="width:21%;background:#e07a3e"></span>
                  <span class="pm-bar-seg" style="width:3%;background:#d5443b"></span>
                </span>
                <span class="pm-rows">
                  <span class="pm-row">
                    <span class="pm-row-label"><span class="pm-dot dot-eagle"></span>Eagle+</span>
                    <span class="pm-row-val">1%<span class="pm-row-target">/ 1%</span></span>
                  </span>
                  <span class="pm-row">
                    <span class="pm-row-label"><span class="pm-dot dot-birdie"></span>Birdie</span>
                    <span class="pm-row-val">18%<span class="pm-row-target">/ 13%</span><span class="pm-row-delta up">+5</span></span>
                  </span>
                  <span class="pm-row">
                    <span class="pm-row-label"><span class="pm-dot dot-par"></span>Par</span>
                    <span class="pm-row-val">56%<span class="pm-row-target">/ 58%</span><span class="pm-row-delta flat">&minus;2</span></span>
                  </span>
                  <span class="pm-row">
                    <span class="pm-row-label"><span class="pm-dot dot-bogey"></span>Bogey</span>
                    <span class="pm-row-val">21%<span class="pm-row-target">/ 24%</span><span class="pm-row-delta up">&minus;3</span></span>
                  </span>
                  <span class="pm-row">
                    <span class="pm-row-label"><span class="pm-dot dot-double"></span>Double+</span>
                    <span class="pm-row-val">3%<span class="pm-row-target">/ 4%</span><span class="pm-row-delta up">&minus;1</span></span>
                  </span>
                </span>

                <span class="pm-section">Where strokes are lost</span>
                <span class="pm-stat loss">
                  <span class="pm-stat-num">&minus;1.34</span>
                  <span class="pm-stat-sub">per round vs scratch</span>
                </span>
                <span class="pm-rows">
                  <span class="pm-row"><span class="pm-row-label">Putting</span><span class="pm-row-val" style="color:#d5443b">&minus;1.14/rd</span></span>
                  <span class="pm-row"><span class="pm-row-label">Approach</span><span class="pm-row-val" style="color:#d5443b">&minus;0.37/rd</span></span>
                  <span class="pm-row"><span class="pm-row-label">Short game</span><span class="pm-row-val" style="color:#d5443b">&minus;0.28/rd</span></span>
                  <span class="pm-row"><span class="pm-row-label">Off the tee</span><span class="pm-row-val" style="color:#1e8f59">+0.45/rd</span></span>
                </span>
              </span>
              <nav class="phone-nav">
                <span class="pn-item active">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l9-7 9 7"/><path d="M5 10v9a1 1 0 0 0 1 1h4v-6h4v6h4a1 1 0 0 0 1-1v-9"/></svg>
                </span>
                <span class="pn-item">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3v18"/><path d="M5 4h11l-3 4 3 4H5"/></svg>
                </span>
                <span class="pn-fab" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                </span>
                <span class="pn-item">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 20V10"/><path d="M12 20V4"/><path d="M18 20v-7"/></svg>
                </span>
                <span class="pn-item">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M4.2 4.2l2.1 2.1M17.7 17.7l2.1 2.1M2 12h3M19 12h3M4.2 19.8l2.1-2.1M17.7 6.3l2.1-2.1"/></svg>
                </span>
              </nav>
            </span>
            </span>
          </span>
          <% } else if (p.quizMock) { %>
          <span class="shot quiz-shot" aria-label="Onboarding interest picker, click a chip to try it">
            <span class="quiz-mock">
              <span class="qm-label">Select all that apply</span>
              <span class="qm-grid">
                <span class="qm-chip selected" role="button" tabindex="0">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="qm-icon"><path d="M4 4.5A2.5 2.5 0 0 1 6.5 2H20v17H6.5A2.5 2.5 0 0 0 4 21.5v-17Z"/><path d="M4 19a2.5 2.5 0 0 1 2.5-2.5H20"/></svg>
                  <span>English</span>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" class="qm-x"><path d="M6 6l12 12M18 6L6 18"/></svg>
                </span>
                <span class="qm-chip" role="button" tabindex="0">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="qm-icon"><rect x="4" y="3" width="16" height="18" rx="2"/><path d="M8 7h8M8 11h1M12 11h1M16 11h1M8 15h1M12 15h1M16 15h1"/></svg>
                  <span>Math</span>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" class="qm-x"><path d="M6 6l12 12M18 6L6 18"/></svg>
                </span>
                <span class="qm-chip" role="button" tabindex="0">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="qm-icon"><path d="M9 2h6M10 2v5.5L5.5 16a3 3 0 0 0 2.6 4.5h7.8a3 3 0 0 0 2.6-4.5L14 7.5V2"/><path d="M7 14h10"/></svg>
                  <span>Science &amp; Nature</span>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" class="qm-x"><path d="M6 6l12 12M18 6L6 18"/></svg>
                </span>
                <span class="qm-chip selected" role="button" tabindex="0">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="qm-icon"><path d="M8 4l-4 8 4 8M16 4l4 8-4 8M13 3l-2 18"/></svg>
                  <span>Coding &amp; Tech</span>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" class="qm-x"><path d="M6 6l12 12M18 6L6 18"/></svg>
                </span>
                <span class="qm-chip" role="button" tabindex="0">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="qm-icon"><circle cx="12" cy="12" r="9"/><path d="M9 20a5 5 0 0 1 0-16M15 4a5 5 0 0 1 0 16"/><circle cx="9" cy="9" r="0.6" fill="currentColor" stroke="none"/><circle cx="15" cy="15" r="0.6" fill="currentColor" stroke="none"/></svg>
                  <span>Arts</span>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" class="qm-x"><path d="M6 6l12 12M18 6L6 18"/></svg>
                </span>
                <span class="qm-chip" role="button" tabindex="0">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="qm-icon"><path d="M9 18V5l11-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="17" cy="16" r="3"/></svg>
                  <span>Music</span>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" class="qm-x"><path d="M6 6l12 12M18 6L6 18"/></svg>
                </span>
              </span>
            </span>
          </span>
          <% } else { %>
          <span class="shot">
            <img src="/img/<%= p.screenshot %>" alt="<%= p.label %>" loading="lazy" />
          </span>
          <% } %>
          <span class="card-foot">
            <span class="card-text-inline">
              <span class="card-label display"><%= p.label %></span>
              <span class="card-tagline"><%= p.tagline %></span>
            </span>
            <span class="card-meta">
              <span class="org"><%= p.org %></span>
              <span class="arrow" aria-hidden="true">&rarr;</span>
            </span>
          </span>
        </a>
        <% }); %>
      </div>
    </section>

    <!-- CONTACT: reach me + ask an AI, as a card -->
    <section class="section" id="contact" aria-label="Contact">
      <div class="bento">
        <div class="card card-text card-xl reveal">
          <div class="card-pad">
            <p class="card-eyebrow">Reach me</p>
            <p class="contact-line">
              <a href="mailto:<%= config.email %>"><%= config.email %></a>
            </p>
            <p class="ask-sub">Or ask an AI about me. It opens with a prompt ready to send.</p>
            <div class="ai-buttons" data-prompt="<%= config.askAiPrompt(config.name, config.domain) %>">
              <button type="button" class="ai-btn" data-provider="chatgpt">ChatGPT</span>
              <button type="button" class="ai-btn" data-provider="claude">Claude</span>
              <button type="button" class="ai-btn" data-provider="perplexity">Perplexity</span>
              <button type="button" class="ai-btn" data-provider="gemini">Gemini</span>
            </div>
            <p class="ask-note" id="ask-note" role="status" aria-live="polite"></p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <p class="foot-meta">© <%= new Date().getFullYear() %> <%= config.name %></p>

  <!-- FLOATING NAV (FAB pill) -->
  <nav class="fab" aria-label="Section navigation">
    <% config.nav.forEach(function(item){ %>
    <a href="#<%= item.target %>" data-target="<%= item.target %>"><%= item.label %></a>
    <% }); %>
  </nav>

  <script src="/script.js"></script>
</body>
</html>
