<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= config.name %> · <%= config.role %></title>

  <meta name="description" content="<%= config.metaDescription %>" />
  <meta name="author" content="<%= config.name %>" />
  <link rel="canonical" href="<%= config.baseUrl %>/" />

  <!-- Open Graph -->
  <meta property="og:type" content="profile" />
  <meta property="og:title" content="<%= config.name %> · <%= config.role %>" />
  <meta property="og:description" content="<%= config.metaDescription %>" />
  <meta property="og:url" content="<%= config.baseUrl %>/" />
  <meta property="profile:first_name" content="Matt" />
  <meta property="profile:last_name" content="Martin" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content="<%= config.name %> · <%= config.role %>" />
  <meta name="twitter:description" content="<%= config.metaDescription %>" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />

  <!-- Structured data: helps an AI answer "who is Matt Martin" accurately -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Matt Martin",
    "alternateName": "Matthew Martin",
    "url": "<%= config.baseUrl %>/",
    "email": "mailto:<%= config.email %>",
    "jobTitle": "Growth & Monetization Product Manager",
    "description": "<%= config.metaDescription %>",
    "knowsAbout": [
      "Product Management", "Growth", "Monetization", "Pricing strategy",
      "Conversion optimization", "Onboarding", "Experimentation",
      "Marketplace products", "Subscription products"
    ],
    "worksFor": { "@type": "Organization", "name": "Independent / open to opportunities" },
    "alumniOf": { "@type": "Organization", "name": "Outschool" },
    "sameAs": [
      "<%= config.roundRecallUrl %>"<% if (config.linkedin) { %>,
      "<%= config.linkedin %>"<% } %>
    ]
  }
  </script>
</head>
<body>
  <a class="skip" href="#work">Skip to work</a>

  <!-- NAME + SOCIALS (the only things outside a card) -->
  <div class="topbar" id="home">
    <span class="mark"><%= config.name %></span>
    <nav class="socials" aria-label="Contact links">
      <a href="mailto:<%= config.email %>">Email</a><% if (config.linkedin) { %>
      <a href="<%= config.linkedin %>" target="_blank" rel="noopener">LinkedIn</a><% } %>
      <a href="<%= config.roundRecallUrl %>" target="_blank" rel="noopener">RoundRecall</a>
    </nav>
  </div>

  <main>
    <!-- HOME: intro card -->
    <section class="section" aria-label="Intro">
      <div class="bento">
        <div class="card card-text card-xl reveal">
          <div class="card-pad">
            <p class="card-eyebrow"><%= config.intro.eyebrow %></p>
            <h1 class="card-head display"><%= config.intro.head %></h1>
            <% config.intro.body.forEach(function(p){ %>
            <p class="card-para"><%= p %></p>
            <% }); %>
          </div>
        </div>
      </div>
    </section>

    <!-- ABOUT: what I do / what I want, all cards -->
    <section class="section" id="about" aria-label="About">
      <div class="bento">
        <div class="card card-text card-md reveal">
          <div class="card-pad">
            <p class="card-eyebrow">What I do</p>
            <ul class="stack">
              <% config.whatIDo.forEach(function(line){ %>
              <li><%= line %></li>
              <% }); %>
            </ul>
          </div>
        </div>

        <div class="card card-text card-md reveal">
          <div class="card-pad">
            <p class="card-eyebrow">What I want</p>
            <ul class="stack">
              <% config.whatIWant.forEach(function(line){ %>
              <li><%= line %></li>
              <% }); %>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- WORK: screenshot-first cards -->
    <section class="section" id="work" aria-label="Work">
      <div class="bento">
        <% projects.forEach(function(p){ %>
        <a class="card card-<%= p.size %> reveal" href="/work/<%= p.slug %>">
          <% if (p.phoneMock) { %>
          <span class="shot phone-shot" aria-label="RoundRecall dashboard preview, scrollable">
            <span class="phone">
              <span class="phone-notch"></span>
              <span class="phone-screen">
                <span class="pm-title">Dashboard</span>

                <span class="pm-leak">
                  <span class="pm-eyebrow">Biggest leak</span>
                  <span class="pm-leak-label">Putts 10&ndash;20 ft</span>
                  <span class="pm-leak-number">&minus;0.77<span class="pm-unit">/round</span></span>
                  <span class="pm-leak-sub">8% made vs scratch &asymp; 22% &middot; across 86 shots</span>
                </span>

                <span class="pm-section">Scoring shape</span>
                <span class="pm-stat">+15%<span class="pm-unit">birdies &minus; doubles per hole</span></span>
                <span class="pm-rows">
                  <span class="pm-row"><span class="pm-dot dot-eagle"></span>Eagle+<b>1%</b></span>
                  <span class="pm-row"><span class="pm-dot dot-birdie"></span>Birdie<b>17%</b></span>
                  <span class="pm-row"><span class="pm-dot dot-par"></span>Par<b>58%</b></span>
                  <span class="pm-row"><span class="pm-dot dot-bogey"></span>Bogey<b>20%</b></span>
                  <span class="pm-row"><span class="pm-dot dot-double"></span>Double+<b>3%</b></span>
                </span>

                <span class="pm-section">Where strokes are lost</span>
                <span class="pm-stat loss">&minus;1.19<span class="pm-unit">per round vs scratch</span></span>
                <span class="pm-rows">
                  <span class="pm-row"><span>Putting</span><b class="loss">&minus;1.15/rd</b></span>
                  <span class="pm-row"><span>Short game</span><b class="loss">&minus;0.31/rd</b></span>
                  <span class="pm-row"><span>Approach</span><b class="loss">&minus;0.06/rd</b></span>
                </span>
              </span>
              <span class="phone-nav">
                <span class="pn-item active">&#8962;</span>
                <span class="pn-item">&#9873;</span>
                <span class="pn-item pn-plus">+</span>
                <span class="pn-item">&#9707;</span>
                <span class="pn-item">&#9881;</span>
              </span>
            </span>
          </span>
          <% } else { %>
          <span class="shot">
            <img src="/img/<%= p.screenshot %>" alt="<%= p.label %>" loading="lazy" />
          </span>
          <% } %>
          <span class="card-foot">
            <span class="card-text-inline">
              <span class="card-label display"><%= p.label %></span>
              <span class="card-tagline"><%= p.tagline %></span>
            </span>
            <span class="card-meta">
              <span class="org"><%= p.org %></span>
              <span class="arrow" aria-hidden="true">&rarr;</span>
            </span>
          </span>
        </a>
        <% }); %>
      </div>
    </section>

    <!-- CONTACT: reach me + ask an AI, as a card -->
    <section class="section" id="contact" aria-label="Contact">
      <div class="bento">
        <div class="card card-text card-xl reveal">
          <div class="card-pad">
            <p class="card-eyebrow">Reach me</p>
            <p class="contact-line">
              <a href="mailto:<%= config.email %>"><%= config.email %></a>
            </p>
            <p class="ask-sub">Or ask an AI about me. It opens with a prompt ready to send.</p>
            <div class="ai-buttons" data-prompt="<%= config.askAiPrompt(config.name, config.domain) %>">
              <button type="button" class="ai-btn" data-provider="chatgpt">ChatGPT</button>
              <button type="button" class="ai-btn" data-provider="claude">Claude</button>
              <button type="button" class="ai-btn" data-provider="perplexity">Perplexity</button>
              <button type="button" class="ai-btn" data-provider="gemini">Gemini</button>
            </div>
            <p class="ask-note" id="ask-note" role="status" aria-live="polite"></p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <p class="foot-meta">© <%= new Date().getFullYear() %> <%= config.name %></p>

  <!-- FLOATING NAV (FAB pill) -->
  <nav class="fab" aria-label="Section navigation">
    <% config.nav.forEach(function(item){ %>
    <a href="#<%= item.target %>" data-target="<%= item.target %>"><%= item.label %></a>
    <% }); %>
  </nav>

  <script src="/script.js"></script>
</body>
</html>
