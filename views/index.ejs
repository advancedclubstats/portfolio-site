                <span class="qm-chip" role="button" tabindex="0">
                  <svg viewBox="0 0 512 512" fill="currentColor" class="qm-icon"><path d="M201.1 57.3c-7 5.3-9.1 10.7-9.1 14.7 0 4.2 2.4 10.1 10.4 15.6 7.8 5.3 13.6 14.6 13.6 25.6 0 17-13.8 30.7-30.7 30.7L56 144c-4.4 0-8 3.6-8 8l0 52.5c7.4-2.9 15.5-4.5 24-4.5 43.1 0 72 39.4 72 80s-28.9 80-72 80c-8.5 0-16.6-1.6-24-4.5L48 456c0 4.4 3.6 8 8 8l100.5 0c-2.9-7.4-4.5-15.5-4.5-24 0-43.1 39.4-72 80-72s80 28.9 80 72c0 8.5-1.6 16.6-4.5 24l52.5 0c4.4 0 8-3.6 8-8l0-129.3c0-17 13.8-30.7 30.7-30.7 11.1 0 20.3 5.8 25.6 13.6 5.5 8 11.4 10.4 15.6 10.4 4 0 9.5-2.1 14.7-9.1s9.3-17.9 9.3-30.9-4-23.8-9.3-30.9-10.7-9.1-14.7-9.1c-4.2 0-10.1 2.4-15.6 10.4-5.3 7.8-14.6 13.6-25.6 13.6-17 0-30.7-13.8-30.7-30.7l0-81.3c0-4.4-3.6-8-8-8l-81.3 0c-17 0-30.7-13.8-30.7-30.7 0-11.1 5.8-20.3 13.6-25.6 8-5.5 10.4-11.4 10.4-15.6 0-4-2.1-9.5-9.1-14.7S245 48 232 48 208.2 52 201.1 57.3zM172.3 18.9C188.5 6.8 209.6 0 232 0S275.5 6.8 291.7 18.9 320 49.5 320 72c0 8.6-1.8 16.7-4.9 24L360 96c30.9 0 56 25.1 56 56l0 44.9c7.3-3.1 15.4-4.9 24-4.9 22.5 0 41 12.2 53.1 28.3s18.9 37.3 18.9 59.7-6.8 43.5-18.9 59.7-30.6 28.3-53.1 28.3c-8.6 0-16.7-1.8-24-4.9l0 92.9c0 30.9-25.1 56-56 56l-78.1 0c-18.7 0-33.9-15.2-33.9-33.9 0-10.1 4.5-18.5 9.9-24.2 4.2-4.3 6.1-9.2 6.1-13.9 0-9.9-10.7-24-32-24s-32 14.1-32 24c0 4.7 1.9 9.5 6.1 13.9 5.5 5.7 9.9 14.1 9.9 24.2 0 18.7-15.2 33.9-33.9 33.9L56 512c-30.9 0-56-25.1-56-56L0 329.9c0-18.7 15.2-33.9 33.9-33.9 10.1 0 18.5 4.5 24.2 9.9 4.3 4.2 9.2 6.1 13.9 6.1 9.9 0 24-10.7 24-32s-14.1-32-24-32c-4.7 0-9.5 1.9-13.9 6.1-5.7 5.5-14.1 9.9-24.2 9.9-18.7 0-33.9-15.2-33.9-33.9L0 152c0-30.9 25.1-56 56-56l92.9 0c-3.1-7.3-4.9-15.4-4.9-24 0-22.5 12.2-41 28.3-53.1z"/></svg>
                  <span>Games &amp; Hobbies</span>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" class="qm-x"><path d="M6 6l12 12M18 6L6 18"/></svg>
                </span>
                <span class="qm-chip" role="button" tabindex="0">
                  <svg viewBox="0 0 448 512" fill="currentColor" class="qm-icon"><path d="M200 464l0 56c0 13.3 10.7 24 24 24s24-10.7 24-24l0-184 32 0c22.1 0 40 17.9 40 40 0 19.4-13.7 35.5-32 39.2l0 48.4c44.9-4 80-41.7 80-87.6 0-48.6-39.4-88-88-88l-32 0 0-192 68 0c19.9 0 36 16.1 36 36s-16.1 36-36 36l-28 0 0 48 28 0c46.4 0 84-37.6 84-84s-37.6-84-84-84l-68 0 0-56c0-13.3-10.7-24-24-24S200-21.3 200-8l0 56-128 0c-30.9 0-56 25.1-56 56s25.1 56 56 56 56-25.1 56-56l0-8 72 0 0 192-36 0c-19.9 0-36-16.1-36-36 0-18.5 14-33.8 32-35.8l0-48.1c-44.5 2.1-80 38.9-80 83.9 0 46.4 37.6 84 84 84l36 0 0 80-32 0c-13.3 0-24 10.7-24 24s10.7 24 24 24l32 0z"/></svg>
                  <span>Health &amp; Wellness</span>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" class="qm-x"><path d="M6 6l12 12M18 6L6 18"/></svg>
                </span>
                <span class="qm-chip" role="button" tabindex="0">
                  <svg viewBox="0 0 448 512" fill="currentColor" class="qm-icon"><path d="M96 24c0-13.3 10.7-24 24-24L328 0c13.3 0 24 10.7 24 24s-10.7 24-24 24l-8 0 0 169.6 120.7 211.2c4.8 8.4 7.3 17.9 7.3 27.6 0 30.7-24.9 55.6-55.6 55.6L55.6 512c-30.7 0-55.6-24.9-55.6-55.6 0-9.7 2.5-19.2 7.3-27.6L128 217.6 128 48 120 48c-13.3 0-24-10.7-24-24zm80 24l0 176c0 4.2-1.1 8.3-3.2 11.9l-38.9 68.1 180.1 0-38.9-68.1c-2.1-3.6-3.2-7.7-3.2-11.9l0-176-96 0zM106.5 352L49 452.6c-.7 1.1-1 2.4-1 3.8 0 4.2 3.4 7.6 7.6 7.6l336.8 0c4.2 0 7.6-3.4 7.6-7.6 0-1.3-.3-2.6-1-3.8l-57.5-100.6-235 0z"/></svg>
                  <span>Test Prep</span>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" class="qm-x"><path d="M6 6l12 12M18 6L6 18"/></svg>
                </span>
                <span class="qm-chip" role="button" tabindex="0">
                  <svg viewBox="0 0 512 512" fill="currentColor" class="qm-icon"><path d="M360 0c44.2 0 80 35.8 80 80 0 26.3-12.7 49.5-32.2 64.1 .1 2.6 .2 5.2 .2 7.9 0 5.4-.3 10.7-.8 15.9 22.9-11.7 51.3-10.7 73.9 5.1l5.8 4.5c25.8 22.2 32.5 59.7 15.9 89.5l-3.9 6.2c-14.3 20.5-31.3 39.1-50.2 55.4 35.7 4.3 63.3 34.6 63.3 71.4l0 24-.4 8.4c-3.7 38.9-32.7 70.4-70.4 77.9l-8.2 1.2c-.4 0-.8 .1-1.2 .1l-6.5 .3c-.4 0-.8 0-1.3 0L88 512C42.5 512 5 477.4 .5 433l-.5-9 0-24c0-36.8 27.6-67.1 63.3-71.4-11-9.4-21.3-19.6-30.8-30.5l-8.9-10.8c-.1-.2-.3-.4-.4-.6l-9.6-12.9-1.2-1.7-2.6-4.2c-.2-.3-.4-.6-.6-1-17.7-31.9-8.8-72.7 21.8-94l5.8-3.7c21.5-12.1 47-12 68-1.4-.5-5.2-.8-10.5-.8-15.9 0-2.7 .1-5.3 .2-7.9-19.5-14.6-32.2-37.8-32.2-64.1 0-44.2 35.8-80 80-80 27.4 0 51.4 13.8 65.8 34.7 12.4-1.8 25.2-2.7 38.2-2.7 13 0 25.8 .9 38.2 2.7 14.4-20.9 38.4-34.7 65.8-34.7zm93.6 212.3c-10.9-7.6-25.8-4.9-33.4 6l0 0c-33.9 48.6-88.8 81.4-151.5 85.3l-3.4 .1c-3 .2-6.1 .3-9.2 .3l-7.8-.2c-.2 0-.5 0-.7-.1-56.3-2.4-106.6-27.9-141.5-67.5l-7.1-8.5-.4-.6-6.2-8.4 0 0-2.1-2.7c-6.9-7.9-18.3-10.3-27.8-6.1l-4 2.3c-10.1 7-13.1 20.5-7.3 31.1l1.6 2.6 8.5 11.5 7.5 9.1c18 20.7 39.4 38.4 63.3 52.2l2.6 1.8c5.8 4.5 9.3 11.5 9.3 19l0 52.4c0 13.2-10.8 24-24 24l-.7 0c-10.2 0-19.2-6.5-22.6-15.8L95.6 396c-1.7-9.9-9.5-17.8-19.3-19.6L72 376c-13.2 0-24 10.7-24 24l0 24 .2 4.1C50.3 448.3 67.3 464 88 464l335.3 0 5.1-.3c18.7-2 33.6-17.1 35.4-35.9l.2-3.8 0-24-.1-2.4c-1.1-11.3-10.1-20.3-21.4-21.4L440 376c-11.8 0-21.7 8.6-23.6 20-1.9 11.5-11.9 20-23.7 20l-.7 0c-13.2 0-24-10.8-24-24l0-52.4c0-8.6 4.6-16.5 12-20.8 31.6-18.3 58.8-43.3 79.6-73.1l1.3-2.1c5.5-9.9 3.3-22.4-5.3-29.8l-1.9-1.5zM256 336c35.3 0 64 28.7 64 64l0 16-128 0 0-16c0-35.3 28.7-64 64-64zM360 48c-13.9 0-25.7 8.9-30.2 21.4-4.1 11.6-16.2 18.2-28.1 15.4-13.5-3.2-28.9-4.7-45.7-4.8s-32.2 1.6-45.7 4.8c-11.9 2.8-24-3.8-28.1-15.4-4.4-12.5-16.3-21.4-30.2-21.4-17.7 0-32 14.3-32 32 0 13.1 7.9 24.4 19.3 29.4 10.3 4.4 16.1 15.4 14.1 26.4-.9 4.8-1.4 10.2-1.4 16.2 0 55.3 43.2 100.5 97.7 103.8 2.1 .1 4.2 .2 6.3 .2 57.4 0 104-46.6 104-104 0-5.9-.5-11.3-1.4-16.2-2.1-11 3.8-22 14.1-26.4 11.4-4.9 19.3-16.3 19.3-29.4 0-17.7-14.3-32-32-32zM256 176c17.7 0 32 10.7 32 24s-14.3 24-32 24-32-10.7-32-24 14.3-24 32-24zm-48-12a20 20 0 1 1 0-40 20 20 0 1 1 0 40zm96 0a20 20 0 1 1 0-40 20 20 0 1 1 0 40z"/></svg>
                  <span>Early Education</span>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" class="qm-x"><path d="M6 6l12 12M18 6L6 18"/></svg>
                </span>
              </span>
            </span>
          </span>
          <% } else if (p.pricingMock) { %>
          <span class="shot mem-shot" aria-label="Outschool membership plan picker, click a plan to select it">
            <span class="mem-mock">
              <span class="mem-card selected" role="radio" aria-checked="true" tabindex="0">
                <span class="mem-credits"><b>80</b> credits</span>
                <span class="mem-price-row">
                  <span class="mem-price">$0</span>
                  <span class="mem-price-sub"><span class="mem-strike">$40 USD</span> / month</span>
                </span>
                <span class="mem-btn primary">Try for free</span>
                <span class="mem-hr"></span>
                <span class="mem-bullets">
                  <span class="mem-bullet"><span class="mem-dot">&bull;</span><span class="mem-bullet-text">Covers <b>~1</b> group class per week</span></span>
                  <span class="mem-bullet"><span class="mem-dot">&bull;</span><span class="mem-bullet-text"><b>Free access</b> to <span class="mem-link">100+ self-paced classes</span></span></span>
                </span>
              </span>
              <span class="mem-card" role="radio" aria-checked="false" tabindex="0">
                <span class="mem-credits"><b>144</b> credits</span>
                <span class="mem-price-row">
                  <span class="mem-price">$70</span>
                  <span class="mem-price-sub">USD / month</span>
                </span>
                <span class="mem-btn outline">Select</span>
                <span class="mem-hr"></span>
                <span class="mem-bullets">
                  <span class="mem-bullet"><span class="mem-dot">&bull;</span><span class="mem-bullet-text"><b>4 bonus credits</b>/mo included</span></span>
                  <span class="mem-bullet"><span class="mem-dot">&bull;</span><span class="mem-bullet-text">Covers <b>~2</b> group classes per week</span></span>
                </span>
              </span>
            </span>
          </span>
          <% } else { %>
          <span class="shot">
            <img src="/img/<%= p.screenshot %>" alt="<%= p.label %>" loading="lazy" />
          </span>
          <% } %>
          <span class="card-foot">
            <span class="card-text-inline">
              <span class="card-label display"><%= p.label %></span>
              <span class="card-tagline"><%= p.tagline %></span>
            </span>
            <span class="card-meta">
              <span class="org"><%= p.org %></span>
              <span class="arrow" aria-hidden="true">&rarr;</span>
            </span>
          </span>
        </a>
        <% }); %>
      </div>
    </section>

    <!-- CONTACT: email + LinkedIn as app-style bento tiles, ask-an-AI below -->
    <section class="section" id="contact" aria-label="Contact">
      <div class="bento">
        <a class="card card-md contact-tile mail-tile reveal" href="mailto:<%= config.email %>">
          <div class="card-pad contact-tile-pad">
            <div class="contact-tile-head">
              <span class="contact-tile-name"><%= config.name %></span>
              <span class="contact-tile-handle"><%= config.email %></span>
            </div>
            <span class="app-icon mail-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none"><path d="M3 6.5c0-.83.67-1.5 1.5-1.5h15c.83 0 1.5.67 1.5 1.5v11c0 .83-.67 1.5-1.5 1.5h-15A1.5 1.5 0 0 1 3 17.5v-11Z" fill="#fff"/><path d="M3.4 6 12 13l8.6-7" stroke="#3b82f6" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/><path d="M3 6.5c0-.83.67-1.5 1.5-1.5h15c.83 0 1.5.67 1.5 1.5v11c0 .83-.67 1.5-1.5 1.5h-15A1.5 1.5 0 0 1 3 17.5v-11Z" stroke="#93c5fd" stroke-width="1"/></svg>
            </span>
            <div class="mail-compose">
              <p class="mail-compose-row"><span class="mail-compose-label">To</span> <%= config.email %></p>
              <p class="mail-compose-subject">Let&rsquo;s chat</p>
              <p class="mail-compose-body">Say hello&hellip;</p>
            </div>
          </div>
          <span class="contact-tile-btn">Email me <span aria-hidden="true">&#8599;</span></span>
        </a>

        <% if (config.linkedin) { %>
        <a class="card card-md contact-tile linkedin-tile reveal" href="<%= config.linkedin %>" target="_blank" rel="noopener">
          <div class="card-pad contact-tile-pad">
            <div class="contact-tile-head">
              <span class="contact-tile-name"><%= config.name %></span>
              <span class="contact-tile-handle">Growth &amp; Monetization PM</span>
            </div>
            <span class="app-icon linkedin-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="#fff"><path d="M6.94 5a1.94 1.94 0 1 1-3.88 0 1.94 1.94 0 0 1 3.88 0ZM3.4 8.75h3.4V21H3.4V8.75Zm6.02 0h3.26v1.68h.05c.45-.86 1.56-1.77 3.22-1.77 3.44 0 4.08 2.27 4.08 5.22V21h-3.4v-5.5c0-1.31-.02-3-1.83-3-1.83 0-2.11 1.43-2.11 2.9V21h-3.4V8.75Z"/></svg>
            </span>
            <p class="linkedin-bio">I find where products leak money. Then I fix it.</p>
          </div>
          <span class="contact-tile-btn">View profile <span aria-hidden="true">&#8599;</span></span>
        </a>
        <% } %>

        <div class="card card-text card-xl reveal">
          <div class="card-pad">
            <p class="card-eyebrow">Ask an AI about me</p>
            <p class="ask-sub">It opens with a prompt ready to send.</p>
            <div class="ai-buttons" data-prompt="<%= config.askAiPrompt(config.name, config.domain) %>">
              <button type="button" class="ai-btn" data-provider="chatgpt">ChatGPT</button>
              <button type="button" class="ai-btn" data-provider="claude">Claude</button>
              <button type="button" class="ai-btn" data-provider="perplexity">Perplexity</button>
              <button type="button" class="ai-btn" data-provider="gemini">Gemini</button>
            </div>
            <p class="ask-note" id="ask-note" role="status" aria-live="polite"></p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <p class="foot-meta">© <%= new Date().getFullYear() %> <%= config.name %></p>

  <!-- FLOATING NAV (FAB pill) -->
  <nav class="fab" aria-label="Section navigation">
    <% config.nav.forEach(function(item){ %>
    <a href="#<%= item.target %>" data-target="<%= item.target %>"><%= item.label %></a>
    <% }); %>
  </nav>

  <script src="/script.js"></script>
</body>
</html>
